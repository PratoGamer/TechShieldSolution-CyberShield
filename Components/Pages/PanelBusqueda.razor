<div class="card bg-secondary bg-opacity-10 border-secondary border-opacity-25 rounded-3 p-4 mb-4">

	<h3 class="h5 text-info mb-3 fw-semibold">Buscador de Errores</h3>

	<div class="input-group mb-3 shadow-sm">
		
		<input class="form-control bg-dark text-white border-secondary border-opacity-25"
			   type="text" placeholder="Ej: ERR_404" @bind-value="codigoBusqueda" @bind-value:event="oninput"/>

		<button class="btn btn-info px4" type="button" @onclick="BuscarCodigo">
			<i class="bi bi-search text-dark"></i>
		</button>
	</div>

	@if (busquedaRealizada)
	{
		<div class="mt-3">
			@if (vecesOcurrido >= 0)
			{
					
				<div class="alert alert-success border-0 d-flex justify-content-between align-items-center m-0 bg-success bg-opacity-25 text-white shadow-sm" role="alert">
					<p class="fw-bold text-success">@codigoEncontrado: @vecesOcurrido veces</p>
				</div>

			}
			else
			{
				<div class="alert alert-warning border-0 d-flex align-items-center gap-2 m-0 bg-warning bg-opacity-25 text-white shadow-sm" role="alert">
					<p class="fw-bold text-warning">@codigoBusqueda: no encontrado</p>
				</div>
			}

		</div>
	}

	<div class="mt-2">

		<h4 class="h6 text-uppercase fw-bold text-secondary mb-3 d-flex align-items-center gap-2">
			5 Errores Frecuentes
		</h4>

	</div>

	<div class="table-responsive rounded-3 border border-secondary border-opacity-25 shadow-sm">
		<table class="table table-dark table-striped table-hover m-0 table-borderless">
			<thead class="table-light bg-opacity-10 border-bottom border-secondary border-opacity-25">
				<tr>
					<th scope="col" class="text-muted ps-3">Posicion</th>
					<th scope="col" class="text-muted ps-3">Código</th>
					<th scope="col" class="text-muted ps-3">Frecuencia</th>
				</tr>
			</thead>
			<tbody>
				@{ int posicion = 1;}
				@foreach (var items in Incidentes)
				{
					<tr>
						<td class="fw-bold text-info ps-3">#@posicion</td>
						<td>
							<code class="text-white bg-secondary bg-opacity-25 px-2 py-1 rounded small border border-secondary border-opacity-25">
								@items.Key
							</code>
						</td>
						<td class="text-end pe-3">
							<span class="badge @(posicion == 1 ? "bg-danger" : "bg-secondary") rounded-pill px-2">
								@items.Value registros
							</span>
						</td>
					</tr>
					posicion++;
				}
			</tbody>
		</table>
	</div>



</div>


@code {

	private String codigoBusqueda = "";
	private String codigoEncontrado = "";
	private int vecesOcurrido = -1;
	private bool busquedaRealizada = false;

	private readonly Dictionary<string, int> Errores = new(StringComparer.OrdinalIgnoreCase)
	{
		{ "ERR-404", 14 },
		{ "ERR-500", 3 },
		{ "ERR-102", 27 },
		{ "ERR-401", 8 }
	};

	private List<KeyValuePair<string, int>> Incidentes { get; set; } = new();

	protected override void OnInitialized()
	{
		Incidentes = Errores.OrderByDescending(x => x.Value).Take(5).ToList();
	}

	private async Task BuscarCodigo()
	{
		codigoEncontrado = codigoBusqueda.Trim().ToUpper();

		if (Errores.TryGetValue(codigoEncontrado, out int conteo))
		{
			vecesOcurrido = conteo;
		}
		else
		{
			vecesOcurrido = -1;
		}

		busquedaRealizada = true;
	}

}
